---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.category === 'legal');
const articles = all.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const slugOf = (a: typeof articles[number]) => a.id.replace(/\.(md|mdx)$/, '').split('/').pop();
---
<BaseLayout
  title="Legal & Documents — SPA, MOT, DOT for Malaysian buyers"
  description="A plain-English dossier on the property paperwork: SPA clauses to read, MOT vs DOT, what your conveyancer should already be checking. Not legal advice."
>
  <section class="border-b-2 border-navy">
    <div class="max-w-[1240px] mx-auto px-5 pt-14 pb-16 grid md:grid-cols-12 gap-10">
      <div class="md:col-span-8">
        <p class="doc-no mb-5">Section 05 · Legal & Documents</p>
        <h1 class="font-display text-[44px] md:text-[64px] leading-[1.05] text-navy" style="font-weight: 500;">
          Read the <span class="italic text-clay">contract</span>. Twice.
        </h1>
        <p class="mt-6 font-display italic text-[20px] text-navy-soft leading-[1.5] max-w-[55ch]">
          The SPA is the only document that decides who pays when something goes wrong. Most buyers sign without reading it. Most conveyancers won’t volunteer to walk you through the parts that matter.
        </p>
      </div>
      <aside class="md:col-span-4 md:border-l md:border-rule-strong md:pl-10 flex flex-col justify-end font-mono text-[12px] uppercase tracking-[0.14em] space-y-3">
        <div class="flex justify-between border-b border-rule pb-2"><dt class="text-navy-mute">Files</dt><dd>{articles.length}</dd></div>
        <div class="flex justify-between border-b border-rule pb-2"><dt class="text-navy-mute">Disclaimer</dt><dd>Not legal advice</dd></div>
        <div class="flex justify-between"><dt class="text-navy-mute">Verify with</dt><dd class="text-clay">Your conveyancer</dd></div>
      </aside>
    </div>
  </section>

  <section class="max-w-[1240px] mx-auto px-5 py-14">
    {articles.length === 0 ? (
      <p class="text-navy-mute py-12 font-mono text-[12px] uppercase tracking-[0.14em]">No files yet — the section is being built.</p>
    ) : (
      <ol class="divide-y divide-rule-strong border-y-2 border-navy">
        {articles.map((a, i) => (
          <li>
            <a href={`/${a.data.category}/${slugOf(a)}/`} class="group grid grid-cols-12 gap-4 py-6 items-baseline hover:bg-paper-deep transition -mx-3 px-3">
              <span class="doc-no col-span-2 md:col-span-1">{String(i + 1).padStart(2, '0')}</span>
              <span class="font-display text-[20px] md:text-[24px] leading-snug col-span-12 md:col-span-9 text-navy group-hover:text-clay transition" style="font-weight: 500;">{a.data.title}</span>
              <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-navy-mute col-span-12 md:col-span-2 md:text-right">{new Intl.DateTimeFormat('en-MY', { day: '2-digit', month: 'short', year: 'numeric' }).format(a.data.publishedAt)}</span>
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</BaseLayout>
