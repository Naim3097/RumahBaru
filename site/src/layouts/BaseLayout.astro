---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../lib/site';
import { organizationSchema, websiteSchema } from '../lib/schema';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  locale?: 'ms' | 'en';
  alternates?: Array<{ locale: 'ms' | 'en'; href: string }>;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  ogImage = `${SITE.url}/og-default.jpg`,
  noindex = false,
  locale = 'ms',
  alternates = [],
} = Astro.props;

const htmlLang = locale === 'en' ? 'en-MY' : 'ms-MY';
const fullTitle = title.includes(SITE.name) ? title : `${title} — ${SITE.name}`;
---
<!doctype html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <meta name="theme-color" content="#16263b" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex
    ? <meta name="robots" content="noindex,follow" />
    : <meta name="robots" content="index,follow,max-image-preview:large" />}

  {alternates.map((a) => (
    <link rel="alternate" hreflang={a.locale === 'en' ? 'en-MY' : 'ms-MY'} href={a.href} />
  ))}
  {alternates.length > 0 && (
    <link rel="alternate" hreflang="x-default" href={alternates.find((a) => a.locale === 'ms')?.href ?? canonical} />
  )}

  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={htmlLang.replace('-', '_')} />
  <meta property="og:site_name" content={SITE.name} />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
  />

  <JsonLd data={organizationSchema()} />
  <JsonLd data={websiteSchema()} />

  {SITE.analytics.plausibleDomain && (
    <script
      defer
      data-domain={SITE.analytics.plausibleDomain}
      src="https://plausible.io/js/script.js"
      is:inline
    ></script>
  )}
</head>
<body class="min-h-screen flex flex-col bg-paper text-navy">
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-navy focus:text-paper focus:px-3 focus:py-2">Skip to content</a>
  <Header />
  <main id="main" class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
