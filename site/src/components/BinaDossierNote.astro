---
/**
 * BinaDossierNote — Hub 3's single contractor reference block.
 *
 * Frame here is "Editor's note" / sidebar appendix, NOT a sales callout
 * (Hub 1's "Editor's pick") or a benchmark table (Hub 2's "Benchmark
 * quote"). Different visual + different copy = different fingerprint
 * across the three hubs.
 *
 * Per anti-PBN policy: ONE follow link to BINA+ per page (this block).
 * The WhatsApp link is nofollow.
 *
 * Used sparingly — only the fit-out cluster opts in via includeFitoutNote.
 */
import { FITOUT_REF } from '../lib/site';

export interface Props {
  variant?: number;
  context?: string;   // e.g. "after VP, before fit-out"
}

const { variant = 0, context } = Astro.props;
const anchor = FITOUT_REF.anchors[variant % FITOUT_REF.anchors.length];
const filed = new Intl.DateTimeFormat('en-MY', { month: 'short', year: 'numeric' }).format(new Date());
---
<aside class="not-prose my-14 border-2 border-navy bg-paper-deep">
  <header class="flex items-center justify-between border-b-2 border-navy px-5 py-3 bg-navy text-paper">
    <p class="font-mono text-[10px] uppercase tracking-[0.18em]">Editor’s note · appendix</p>
    <p class="font-mono text-[10px] uppercase tracking-[0.14em] opacity-70">Filed {filed}</p>
  </header>

  <div class="p-6 md:p-7">
    <p class="label mb-3">When you cross from buyer to renovator</p>
    <p class="font-display text-[22px] md:text-[24px] leading-snug text-navy mb-4" style="font-weight: 500;">
      The fit-out studio we point first-time owners to — when they ask, and only when they ask.
    </p>
    <p class="text-[15px] text-navy-soft leading-[1.7] max-w-[60ch] mb-5">
      Most of this dossier is deliberately neutral on contractors — too early in the journey, and the temptation to over-spec is real. But once your CCC is settled and your defect list is filed, readers consistently ask: <em>who do we actually call?</em> Our standing answer is <a href={FITOUT_REF.url} class="font-medium text-navy underline decoration-clay decoration-2 underline-offset-4 hover:bg-clay-soft">{anchor.text}</a>{context ? ` — typically ${context}.` : '.'} They don’t pay us. They publish itemised rates, which is the only reason we’re comfortable naming a single name in a publication that otherwise doesn’t.
    </p>
    <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-rule-strong">
      <a
        href={FITOUT_REF.whatsapp}
        rel="nofollow noopener"
        class="font-mono text-[11px] uppercase tracking-[0.14em] text-clay hover:underline"
      >→ WhatsApp the studio (Shah Alam)</a>
      <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-navy-mute">No referral fee · Single source · Disclosed</span>
    </div>
  </div>
</aside>
